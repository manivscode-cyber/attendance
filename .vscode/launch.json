{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attendance Flask App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app.py",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "FLASK_DEBUG": "1"
            }
        }
    ]
}
