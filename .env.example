# Copy this file to .env and replace the sample values.

GODIGITAL_MANAGER_RECOVERY_EMAIL=your-recovery-email@gmail.com

GODIGITAL_SMTP_HOST=smtp.gmail.com
GODIGITAL_SMTP_PORT=587
GODIGITAL_SMTP_USE_TLS=1
GODIGITAL_SMTP_USE_SSL=0
GODIGITAL_SMTP_USERNAME=your-sender@gmail.com
GODIGITAL_SMTP_PASSWORD=your-16-char-app-password
GODIGITAL_SMTP_FROM_EMAIL=your-sender@gmail.com
